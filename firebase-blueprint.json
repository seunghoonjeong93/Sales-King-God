{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Information about a client or customer site.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "location": { "type": "string" },
        "contactPerson": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Report": {
      "title": "Trip Report",
      "description": "A field report from a business trip or meeting.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" },
        "fullTranscript": { "type": "string" },
        "voiceMemoUrl": { "type": "string" },
        "receipts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "merchant": { "type": "string" },
              "date": { "type": "string" }
            }
          }
        },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" }
      },
      "required": ["customerId", "date", "authorId"]
    },
    "ActionItem": {
      "title": "Action Item",
      "description": "A specific task generated from a report.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "task": { "type": "string" },
        "assignee": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"] },
        "category": { "type": "string", "enum": ["견적", "샘플", "도면수정", "사양협의", "기타"] }
      },
      "required": ["task", "status", "customerId"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customer details."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Trip reports generated by sales staff."
    },
    "/actionItems/{actionItemId}": {
      "schema": "ActionItem",
      "description": "Tasks extracted from reports for follow-up."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    }
  }
}
